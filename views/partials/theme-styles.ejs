<style>
  :root {
    --bg-1: #0f172a;
    --bg-2: #1e1b4b;
    --card: rgba(15, 23, 42, 0.72);
    --card-border: rgba(148, 163, 184, 0.14);
    --text: #f8fafc;
    --muted: #94a3b8;
    --accent: #38bdf8;
    --accent-dim: #0ea5e9;
    --error: #f87171;
    --success: #4ade80;
    --input-bg: rgba(15, 23, 42, 0.65);
    --radius: 16px;
    --shadow: 0 24px 48px -12px rgba(0, 0, 0, 0.45);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: "DM Sans", system-ui, sans-serif;
    color: var(--text);
    background: radial-gradient(
        ellipse 120% 80% at 50% -20%,
        rgba(56, 189, 248, 0.22),
        transparent
      ),
      linear-gradient(155deg, var(--bg-1), var(--bg-2) 55%, #0f172a);
    line-height: 1.5;
  }

  .wrap {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .card {
    width: 100%;
    max-width: 440px;
    background: var(--card);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 2.25rem 2rem 2rem;
  }

  .brand {
    text-align: center;
    margin-bottom: 1.75rem;
  }

  .brand h1 {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .brand p {
    margin: 0.35rem 0 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .alert {
    border-radius: 12px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
    display: none;
  }

  .alert.is-visible {
    display: block;
  }

  .alert--error {
    background: rgba(248, 113, 113, 0.12);
    border: 1px solid rgba(248, 113, 113, 0.35);
    color: #fecaca;
  }

  .alert--success {
    background: rgba(74, 222, 128, 0.12);
    border: 1px solid rgba(74, 222, 128, 0.35);
    color: #bbf7d0;
  }

  .field {
    margin-bottom: 1.1rem;
  }

  label {
    display: block;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--muted);
    margin-bottom: 0.35rem;
  }

  input,
  select,
  textarea {
    width: 100%;
    padding: 0.7rem 0.85rem;
    font-family: inherit;
    font-size: 0.9375rem;
    color: var(--text);
    background: var(--input-bg);
    border: 1px solid var(--card-border);
    border-radius: 10px;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  textarea {
    min-height: 88px;
    resize: vertical;
  }

  input::placeholder,
  textarea::placeholder {
    color: rgba(148, 163, 184, 0.55);
  }

  input:hover,
  select:hover,
  textarea:hover {
    border-color: rgba(148, 163, 184, 0.28);
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.2);
  }

  .row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  @media (max-width: 480px) {
    .row-2 {
      grid-template-columns: 1fr;
    }
  }

  .hint {
    font-size: 0.75rem;
    color: var(--muted);
    margin-top: 0.25rem;
  }

  .match-hint {
    font-size: 0.75rem;
    margin-top: 0.25rem;
    min-height: 1.25rem;
  }

  .match-hint--ok {
    color: var(--success);
  }

  .match-hint--bad {
    color: var(--error);
  }

  .pw-row {
    position: relative;
  }

  .toggle-pw {
    position: absolute;
    right: 0.6rem;
    top: 50%;
    transform: translateY(-50%);
    background: transparent;
    border: none;
    color: var(--muted);
    font-size: 0.75rem;
    cursor: pointer;
    font-family: inherit;
    padding: 0.25rem 0.35rem;
    border-radius: 6px;
  }

  .toggle-pw:hover {
    color: var(--text);
    background: rgba(148, 163, 184, 0.12);
  }

  .toggle-pw:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .submit {
    width: 100%;
    margin-top: 0.5rem;
    padding: 0.85rem 1rem;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 600;
    color: #0f172a;
    background: linear-gradient(135deg, var(--accent), var(--accent-dim));
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: transform 0.12s ease, filter 0.12s ease, opacity 0.12s;
  }

  .submit:hover:not(:disabled) {
    filter: brightness(1.06);
  }

  .submit:active:not(:disabled) {
    transform: scale(0.98);
  }

  .submit:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .submit-inline {
    width: auto;
    min-width: 140px;
    margin-top: 0.75rem;
  }

  .foot {
    text-align: center;
    margin-top: 1.35rem;
    font-size: 0.8125rem;
    color: var(--muted);
  }

  .foot a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }

  .foot a:hover {
    text-decoration: underline;
  }

  .token-box {
    margin-top: 0.75rem;
    padding: 0.65rem 0.75rem;
    background: rgba(15, 23, 42, 0.5);
    border-radius: 8px;
    font-size: 0.7rem;
    word-break: break-all;
    color: var(--muted);
    font-family: ui-monospace, monospace;
  }

  /* Jobs dashboard */
  .app-shell {
    max-width: 960px;
    margin: 0 auto;
    padding: 1.75rem 1.25rem 3rem;
    min-height: 100vh;
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .page-header h1 {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .header-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
  }

  .muted-small {
    font-size: 0.875rem;
    color: var(--muted);
  }

  .btn-ghost {
    display: inline-block;
    padding: 0.5rem 0.9rem;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
    background: rgba(148, 163, 184, 0.12);
    border: 1px solid var(--card-border);
    border-radius: 10px;
    text-decoration: none;
    cursor: pointer;
  }

  .btn-ghost:hover {
    background: rgba(148, 163, 184, 0.2);
  }

  .btn-danger {
    background: rgba(248, 113, 113, 0.15);
    border-color: rgba(248, 113, 113, 0.4);
    color: #fecaca;
  }

  .btn-danger:hover {
    background: rgba(248, 113, 113, 0.28);
  }

  .btn-sm {
    padding: 0.4rem 0.7rem;
    font-size: 0.8125rem;
  }

  .add-panel {
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    margin-bottom: 2rem;
    box-shadow: var(--shadow);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .add-panel summary {
    padding: 1rem 1.25rem;
    cursor: pointer;
    font-weight: 600;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    user-select: none;
  }

  .add-panel summary::-webkit-details-marker {
    display: none;
  }

  .add-panel summary::before {
    content: "+";
    font-weight: 700;
    color: var(--accent);
    font-size: 1.15rem;
    line-height: 1;
  }

  .add-panel[open] summary::before {
    content: "−";
  }

  .add-panel .panel-body {
    padding: 0 1.25rem 1.25rem;
    border-top: 1px solid var(--card-border);
  }

  .job-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .job-card {
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    box-shadow: var(--shadow);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .job-card h2 {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 600;
  }

  .status-pill {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
    background: rgba(56, 189, 248, 0.15);
    color: var(--accent);
  }

  .job-card .meta {
    font-size: 0.8125rem;
    color: var(--muted);
  }

  .job-card .salary {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #e2e8f0;
  }

  .job-card .desc {
    font-size: 0.8125rem;
    color: #cbd5e1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .btn-row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: 0.65rem;
  }

  .btn-row form {
    display: inline;
  }

  .empty-state {
    text-align: center;
    padding: 2.5rem 1rem;
    color: var(--muted);
    background: var(--card);
    border: 1px dashed var(--card-border);
    border-radius: var(--radius);
  }

  .card-wide {
    width: 100%;
    max-width: 560px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
  }

  .back-link:hover {
    text-decoration: underline;
  }
</style>
